---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pricing | Bodhic AI">
	<div style="max-width: 800px; margin: 0 auto; text-align: center; padding: 4rem 0;">
		<h1>Transparent Pricing</h1>
		<p style="color: var(--text-secondary); margin-top: 1rem; font-size: 1.25rem;">We believe in fair monetization for creators.</p>
		
		<div class="grid" style="margin-top: 3rem;">
			<div class="glass-card">
				<h2>For Sellers</h2>
				<p style="font-size: 2.5rem; font-weight: bold; margin: 1rem 0; color: var(--accent-color);">90% <span style="font-size: 1rem; color: var(--text-secondary); font-weight: normal;">Payout</span></p>
				<p>Keep more of your hard-earned money compared to traditional 80% platform cuts.</p>
			</div>
			<div class="glass-card">
				<h2>For Buyers</h2>
				<p style="font-size: 2.5rem; font-weight: bold; margin: 1rem 0; color: var(--accent-color);">Zero <span style="font-size: 1rem; color: var(--text-secondary); font-weight: normal;">Markup</span></p>
				<p>Pay in your local currency. No hidden conversion fees.</p>
			</div>
		</div>
	</div>
</Layout>
