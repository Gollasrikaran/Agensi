---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bodhic AI — The AI Agent Skill Marketplace.">
	<section class="hero">
		<span class="eyebrow">✦ Bodhic AI Marketplace</span>
		<h1>Build smarter agents.<br/><span class="gradient-text">Ship faster.</span></h1>
		<p>
			Discover, buy, and sell prompt artifacts built for AI agents.
			Every skill is scanned for prompt injections and security threats before it goes live.
		</p>
		<div class="cta-row">
			<a href="/browse" class="btn btn-primary btn-lg">Explore Skills →</a>
			<a href="/sell" class="btn btn-secondary btn-lg">Start Selling</a>
		</div>

		<div class="stat-row">
			<div class="stat">
				<div class="stat-value gradient-text">2-Tier</div>
				<div class="stat-label">Security Scan</div>
			</div>
			<div class="stat">
				<div class="stat-value">80%</div>
				<div class="stat-label">Creator Revenue</div>
			</div>
			<div class="stat">
				<div class="stat-value">₹ INR</div>
				<div class="stat-label">Direct Payouts</div>
			</div>
		</div>
	</section>

	<!-- Features -->
	<section class="band">
		<div style="text-align: center; margin-bottom: var(--space-3xl);">
			<span class="eyebrow" style="display: inline-block; margin-bottom: var(--space-md);">Why Bodhic</span>
			<h2>Everything you need to<br/><span class="gradient-text-warm">monetize AI skills.</span></h2>
		</div>
		<div class="grid-3">
			<div class="card">
				<div style="font-size: 28px; margin-bottom: var(--space-md);">🛡️</div>
				<h4><span class="feature-num">01</span>Advanced Security</h4>
				<p style="font-size: 14px;">
					Tier-1 synchronous scanner detects prompt injections, leaked secrets, and excessive agency claims before a skill goes live.
				</p>
			</div>
			<div class="card">
				<div style="font-size: 28px; margin-bottom: var(--space-md);">💰</div>
				<h4><span class="feature-num">02</span>Flat 20% Fee</h4>
				<p style="font-size: 14px;">
					Industry-leading split — creators keep 80% of every sale. No hidden charges, no tiered pricing games.
				</p>
			</div>
			<div class="card">
				<div style="font-size: 28px; margin-bottom: var(--space-md);">⚡</div>
				<h4><span class="feature-num">03</span>Direct Payouts</h4>
				<p style="font-size: 14px;">
					Sellers get paid via UPI bank transfers in INR. No middlemen, no delays — straight from our ledger to your account.
				</p>
			</div>
		</div>
	</section>

	<!-- CTA Band -->
	<section class="band-brand">
		<div style="text-align: center; max-width: 600px; margin: 0 auto; position: relative; z-index: 1;">
			<h2 style="margin-bottom: var(--space-md);">Monetize your expertise.</h2>
			<p style="color: rgba(255,255,255,0.7); font-size: 17px; margin-bottom: var(--space-xl);">
				Package your best prompts as reusable AI skills. Set your price in INR, get paid when someone buys, and let our security scanner build trust for you.
			</p>
			<a href="/sell" class="btn btn-lg" style="background: white; color: var(--primary) !important; border-color: transparent; font-weight: 700;">Start Selling →</a>
		</div>
	</section>
</Layout>
