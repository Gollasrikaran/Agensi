---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bodhic AI - Buy and Sell AI Agent Skills">
	<section class="hero">
		<h1>The Most Secure AI Agent Skill Marketplace</h1>
		<p>
			Discover, buy, and sell prompt artifacts designed for downstream AI agents. 
			Every skill is rigorously scanned for prompt injections and security threats.
		</p>
		<div style="display: flex; gap: var(--space-md); margin-top: var(--space-sm);">
			<a href="/browse" class="btn btn-primary" style="font-size: 16px; padding: 12px 24px;">Explore Skills</a>
			<a href="/sell" class="btn btn-secondary" style="font-size: 16px; padding: 12px 24px;">Start Selling</a>
		</div>
	</section>

	<section style="margin-top: var(--space-4xl);">
		<h2 style="font-size: 32px; letter-spacing: -1.28px; text-align: center;">Why Choose Bodhic AI?</h2>
		<div class="grid">
			<div class="glass-card">
				<h3 style="font-size: 20px; font-weight: 600;"><span style="color: var(--mute); margin-right: 8px;">01.</span> Advanced Security</h3>
				<p style="color: var(--body); font-size: 14px; margin-top: 12px;">Our Tier-1 synchronous scanner detects prompt injections, secrets, and excessive agency claims before a skill even goes live.</p>
			</div>
			<div class="glass-card">
				<h3 style="font-size: 20px; font-weight: 600;"><span style="color: var(--mute); margin-right: 8px;">02.</span> Flat Platform Fee</h3>
				<p style="color: var(--body); font-size: 14px; margin-top: 12px;">We take an industry-leading 20% platform fee, meaning creators keep 80% of all their earnings on the platform.</p>
			</div>
			<div class="glass-card">
				<h3 style="font-size: 20px; font-weight: 600;"><span style="color: var(--mute); margin-right: 8px;">03.</span> Direct Payouts</h3>
				<p style="color: var(--body); font-size: 14px; margin-top: 12px;">Sellers get paid quickly and reliably via direct UPI bank transfers in INR directly from our secure ledger.</p>
			</div>
		</div>
	</section>
</Layout>
