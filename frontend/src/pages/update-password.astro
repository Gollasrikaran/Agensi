---
import Layout from '../layouts/Layout.astro';
import UpdatePasswordIsland from '../components/UpdatePasswordIsland.tsx';
---
<Layout 
	title="Update Password — Bodhic AI"
	description="Set a new password for your Bodhic AI account."
>
	<div style="max-width: 420px; margin: var(--space-5xl) auto;">
		<div style="text-align: center; margin-bottom: var(--space-xl);">
			<span class="eyebrow" style="font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--primary); text-transform: uppercase; letter-spacing: 2px; padding: 6px 16px; background: var(--primary-soft); border-radius: var(--radius-pill); border: 1px solid rgba(108, 60, 225, 0.15); display: inline-block;">security</span>
			<h1 style="font-size: 36px; margin-top: var(--space-md); margin-bottom: var(--space-xs);">Reset Password</h1>
			<p style="color: var(--mute);">Please enter your new password below.</p>
		</div>
		<div class="card" style="padding: var(--space-xl);">
			<UpdatePasswordIsland client:load />
		</div>
	</div>
</Layout>
