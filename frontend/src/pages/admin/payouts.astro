---
import Layout from '../../layouts/Layout.astro';
import PayoutsIsland from '../../components/PayoutsIsland.tsx';
---

<Layout title="Admin Ledger — Bodhic AI">
    <div style="max-width: 1200px; margin: 0 auto; padding-top: var(--space-2xl);">
        <div style="margin-bottom: var(--space-xl); display: flex; justify-content: space-between; align-items: start;">
            <div>
                <span class="eyebrow" style="font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--primary); text-transform: uppercase; letter-spacing: 2px; padding: 6px 16px; background: var(--primary-soft); border-radius: var(--radius-pill); border: 1px solid rgba(108, 60, 225, 0.15); display: inline-block; margin-bottom: var(--space-md);">ledger</span>
                <h1 style="font-size: 36px; margin-bottom: var(--space-xs);">Admin Ledger</h1>
                <p style="color: var(--body); font-size: 16px;">Review and process creator payout requests.</p>
            </div>
            <a href="/admin" class="btn btn-secondary">← Back to Admin</a>
        </div>

        <PayoutsIsland client:load />
    </div>
</Layout>
