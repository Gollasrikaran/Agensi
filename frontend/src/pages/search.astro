---
import Layout from '../layouts/Layout.astro';
import SearchIsland from '../components/SearchIsland.tsx';
---

<Layout 
	title="Search Results — Bodhic AI" 
	description="Search results for AI agent skills and prompts on Bodhic AI."
>
	<div style="max-width: 1200px; margin: 0 auto; padding-top: var(--space-2xl);">
		<div style="margin-bottom: var(--space-xl);">
			<span class="eyebrow" style="font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--primary); text-transform: uppercase; letter-spacing: 2px; padding: 6px 16px; background: var(--primary-soft); border-radius: var(--radius-pill); border: 1px solid rgba(108, 60, 225, 0.15); display: inline-block; margin-bottom: var(--space-md);">Search</span>
			<h1 style="font-size: 36px; margin-bottom: var(--space-xs);">Search Results</h1>
			<p style="color: var(--body); font-size: 16px;" id="search-subtitle">Searching...</p>
		</div>

		<SearchIsland client:load />
	</div>
</Layout>
