---
import Layout from '../../../layouts/Layout.astro';
import SellerDashboardIsland from '../../../components/SellerDashboardIsland.tsx';
---
<Layout 
	title="Seller Dashboard — Bodhic AI"
	description="Manage your listed AI agent skills, track your sales, and monitor your creator analytics on Bodhic AI."
>
	<div style="max-width: 1000px; margin: 0 auto; padding-top: var(--space-2xl);">
		<div style="margin-bottom: var(--space-xl);">
			<div style="display: flex; gap: var(--space-md); margin-bottom: var(--space-lg); border-bottom: 1px solid var(--hairline);">
				<a href="/dashboard/buyer" style="padding: var(--space-sm) var(--space-md); font-weight: 500; color: var(--text-muted); text-decoration: none; transition: color 0.2s;">Buyer Dashboard</a>
				<a href="/dashboard/seller" style="padding: var(--space-sm) var(--space-md); font-weight: 600; color: var(--primary); border-bottom: 2px solid var(--primary); text-decoration: none;">Seller Dashboard</a>
			</div>
			<div style="display: flex; justify-content: space-between; align-items: start;">
				<div>
					<span class="eyebrow" style="font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--primary); text-transform: uppercase; letter-spacing: 2px; padding: 6px 16px; background: var(--primary-soft); border-radius: var(--radius-pill); border: 1px solid rgba(108, 60, 225, 0.15); display: inline-block; margin-bottom: var(--space-md);">creator</span>
					<h1 style="font-size: 36px; margin-bottom: var(--space-xs);">Dashboard</h1>
					<p style="color: var(--body); font-size: 16px;">Manage your listed skills and track sales.</p>
				</div>
				<a href="/sell" class="btn btn-primary">Upload New Skill →</a>
			</div>
		</div>
		<SellerDashboardIsland client:load />
	</div>
</Layout>
