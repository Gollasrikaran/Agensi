---
import Layout from '../../../layouts/Layout.astro';
import BuyerDashboardIsland from '../../../components/BuyerDashboardIsland.tsx';
---
<Layout 
	title="Buyer Dashboard — Bodhic AI"
	description="Access your purchased AI agent skills, prompts, and workflows in your private buyer dashboard."
>
	<div style="max-width: 1000px; margin: 0 auto; padding-top: var(--space-2xl);">
		<div style="margin-bottom: var(--space-xl);">
			<span class="eyebrow" style="font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--primary); text-transform: uppercase; letter-spacing: 2px; padding: 6px 16px; background: var(--primary-soft); border-radius: var(--radius-pill); border: 1px solid rgba(108, 60, 225, 0.15); display: inline-block; margin-bottom: var(--space-md);">buyer</span>
			<h1 style="font-size: 36px; margin-bottom: var(--space-xs);">Dashboard</h1>
			<p style="color: var(--body); font-size: 16px;">View your purchased skills and access artifacts.</p>
		</div>
		<BuyerDashboardIsland client:load />
	</div>
</Layout>
