---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact Us - Bodhic AI">
    <div style="max-width: 800px; margin: 0 auto; padding: var(--space-2xl) 0;">
        <h1 style="font-size: 36px; margin-bottom: var(--space-lg);">Contact Us</h1>
        <div style="color: var(--body); line-height: 1.8; font-size: 16px;">
            <p style="margin-bottom: var(--space-xl);">We're here to help. Whether you have a question about a skill you purchased, need help setting up your seller profile, or have inquiries regarding our platform, feel free to reach out.</p>
            
            <div class="card" style="padding: var(--space-xl); margin-bottom: var(--space-lg);">
                <h3 style="font-size: 18px; color: var(--ink); margin-bottom: var(--space-sm);">Customer Support</h3>
                <p style="margin: 0;">Email: <a href="mailto:support@bodhicai.tech?subject=Support%20Inquiry" style="color: var(--primary);">support@bodhicai.tech</a></p>
                <p style="margin-top: 8px; color: var(--mute); font-size: 14px;">Our support team typically responds within 24 hours.</p>
            </div>
            
            <div class="card" style="padding: var(--space-xl); margin-bottom: var(--space-lg);">
                <h3 style="font-size: 18px; color: var(--ink); margin-bottom: var(--space-sm);">Business Inquiries</h3>
                <p style="margin: 0;">Email: <a href="mailto:support@bodhicai.tech?subject=Business%20Inquiry" style="color: var(--primary);">support@bodhicai.tech</a></p>
            </div>
            
            <div class="card" style="padding: var(--space-xl);">
                <h3 style="font-size: 18px; color: var(--ink); margin-bottom: var(--space-sm);">Registered Address</h3>
                <p style="margin: 0;">Bodhic AI Inc.<br />
                Bangalore, Karnataka<br />
                India</p>
            </div>
        </div>
    </div>
</Layout>
