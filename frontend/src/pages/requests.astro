---
import Layout from '../layouts/Layout.astro';
import BountyBoardIsland from '../components/BountyBoardIsland.tsx';
---

<Layout 
	title="Bounty Board & Skill Requests — Bodhic AI"
	description="Post requests for custom AI agent skills or claim open bounties to earn INR directly to your wallet."
>
	<div style="max-width: 1200px; margin: 0 auto; padding-top: var(--space-2xl);">
		<div style="margin-bottom: var(--space-xl);">
			<span class="eyebrow" style="font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--primary); text-transform: uppercase; letter-spacing: 2px; padding: 6px 16px; background: var(--primary-soft); border-radius: var(--radius-pill); border: 1px solid rgba(108, 60, 225, 0.15); display: inline-block; margin-bottom: var(--space-md);">bounties</span>
			<h1 style="font-size: 36px; margin-bottom: var(--space-xs);">Skill Requests & Bounties</h1>
			<p style="color: var(--body); font-size: 16px;">Can't find the skill you need? Post a request. Creators: claim bounties to earn.</p>
		</div>

		<BountyBoardIsland client:load />
	</div>
</Layout>
