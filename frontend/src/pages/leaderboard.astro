---
import Layout from '../layouts/Layout.astro';
import LeaderboardIsland from '../components/LeaderboardIsland.tsx';
---

<Layout 
	title="Leaderboard & Contests — Bodhic AI"
	description="See the top-voted AI agent skills and participate in our monthly creator contests."
>
	<div style="max-width: 1200px; margin: 0 auto; padding-top: var(--space-2xl);">
		<div style="text-align: center; margin-bottom: var(--space-xl);">
			<span class="eyebrow" style="font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--primary); text-transform: uppercase; letter-spacing: 2px; padding: 6px 16px; background: var(--primary-soft); border-radius: var(--radius-pill); border: 1px solid rgba(108, 60, 225, 0.15); display: inline-block; margin-bottom: var(--space-md);">leaderboard</span>
			<h1 style="font-size: 48px; margin-bottom: var(--space-xs); letter-spacing: -1px;">
				Top Voted <span class="gradient-text">Skills</span>
			</h1>
			<p style="color: var(--body); font-size: 18px; max-width: 600px; margin: 0 auto;">
				Vote for your favorite skills. The top 3 skills at the end of each month win a cash bonus from the Bodhic AI Creator Fund.
			</p>
		</div>

		<LeaderboardIsland client:load />
	</div>
</Layout>
