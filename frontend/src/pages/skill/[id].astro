---
import Layout from '../../layouts/Layout.astro';
import CheckoutIsland from '../../components/CheckoutIsland.tsx';
import ReviewsIsland from '../../components/ReviewsIsland.tsx';
import McpTestIsland from '../../components/McpTestIsland.tsx';



const { id } = Astro.params;

let skill: any = null;
try {
	const res = await fetch(`${import.meta.env.PUBLIC_API_URL || 'http://localhost:8000'}/api/skills/${id}`);
	if (res.ok) skill = await res.json();
} catch (e) {
	console.error(e);
}

const jsonLd = skill ? JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Product",
	"name": skill.title,
	"description": skill.description,
	"image": skill.cover_image_url || "https://bodhic.app/og-image.png",
	"offers": {
		"@type": "Offer",
		"price": skill.base_price_inr || 0,
		"priceCurrency": "INR",
		"availability": "https://schema.org/InStock"
	},
	"aggregateRating": skill.review_count > 0 ? {
		"@type": "AggregateRating",
		"ratingValue": skill.average_rating || 5,
		"reviewCount": skill.review_count
	} : undefined
}) : undefined;
---

<Layout 
	title={skill ? `${skill.title} — Bodhic AI` : "Skill Not Found"}
	description={skill ? skill.description : "This AI agent skill could not be found."}
	image={skill?.cover_image_url}
	type="product"
	jsonLd={jsonLd}
>
	{!skill ? (
		<div style="text-align: center; padding: var(--space-5xl);">
			<h2 style="font-size: 24px; margin-bottom: var(--space-md);">Skill not found.</h2>
			<a href="/browse" class="btn btn-primary">← Back to Browse</a>
		</div>
	) : (
		<div style="max-width: 800px; margin: 0 auto; padding-top: var(--space-xl);">
			<div style="margin-bottom: var(--space-xl);">
				<div style="display: flex; gap: var(--space-xs); margin-bottom: var(--space-sm);">
					<span class="badge" style="text-transform: uppercase; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.5px;">{skill.category}</span>
					{skill.moderation_status === 'approved' ? (
						<span style="display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; background: rgba(16, 185, 129, 0.1); color: var(--success); border: 1px solid rgba(16, 185, 129, 0.3); border-radius: 12px; font-size: 12px; font-weight: 600; box-shadow: 0 0 12px rgba(16, 185, 129, 0.2);">
							🛡️ Passed OWASP Security Scan
						</span>
					) : (
						<span class="badge warning">⏳ Pending Review</span>
					)}
					<span style="display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; background: var(--primary-soft); color: var(--primary); border: 1px solid var(--primary); border-radius: 12px; font-size: 12px; font-weight: 600; box-shadow: 0 0 12px var(--primary-soft);">
						🔌 MCP Ready
					</span>
				</div>
				<h1 style="font-size: 48px; margin-bottom: var(--space-xs);">{skill.title}</h1>
			</div>

			<div class="card" style="margin-bottom: var(--space-lg); padding: var(--space-xl);">
				<h3 style="font-size: 16px; color: var(--mute); font-weight: 600; margin-bottom: var(--space-sm);">Description</h3>
				<p style="color: var(--body); font-size: 16px; white-space: pre-wrap; line-height: 1.7;">{skill.description}</p>
			</div>

			<div class="card" style="margin-bottom: var(--space-lg); padding: var(--space-xl);">
				<h3 style="font-size: 16px; color: var(--mute); font-weight: 600; margin-bottom: var(--space-sm);">Security Scan</h3>
				<div style="display: flex; flex-direction: column; gap: var(--space-xs); font-size: 14px; color: var(--body);">
					<div><strong style="color: var(--ink);">Status:</strong> {skill.moderation_status === 'approved' ? '✓ Passed' : '⚠ Flagged'}</div>
					<div><strong style="color: var(--ink);">Checks:</strong> <span style="font-family: var(--font-mono); font-size: 12px;">OWASP LLM01, LLM06, LLM04</span></div>
					{skill.scan_summary_json?.issues && skill.scan_summary_json.issues.length > 0 && (
						<div style="color: var(--error); margin-top: var(--space-sm);">
							<strong>Issues:</strong>
							<ul style="margin-left: var(--space-lg); margin-top: var(--space-xxs);">
								{skill.scan_summary_json.issues.map((i: any) => (
									<li style="margin-bottom: 2px;">{i.rule}: {i.description}</li>
								))}
							</ul>
						</div>
					)}
				</div>
			</div>

			<div class="card" style="margin-bottom: var(--space-lg); padding: var(--space-xl);">
				<h3 style="font-size: 20px; color: var(--ink); font-weight: 700; margin-bottom: var(--space-md); display: flex; align-items: center; gap: 8px;">
					Buyer Reviews
					{skill.review_count > 0 && (
						<span style="font-size: 14px; font-weight: 500; color: var(--mute); background: var(--canvas-soft); padding: 2px 8px; border-radius: 12px;">
							★ {skill.average_rating ? Number(skill.average_rating).toFixed(1) : 0} ({skill.review_count})
						</span>
					)}
				</h3>
				<ReviewsIsland client:load skillId={skill.id} />
			</div>

			<CheckoutIsland client:load skillId={skill.id} basePrice={skill.base_price_inr || skill.base_price_usd || 0} />
			<McpTestIsland client:load skillId={skill.id} />
		</div>
	)}
</Layout>
