---
import Layout from '../../layouts/Layout.astro';
import CheckoutIsland from '../../components/CheckoutIsland.tsx';

export async function getStaticPaths() {
	try {
		const res = await fetch('http://localhost:8000/api/skills');
		if (res.ok) {
			const skills = await res.json();
			return skills.map((s: any) => ({
				params: { id: s.id }
			}));
		}
	} catch (e) {
		console.error(e);
	}
	return [];
}

const { id } = Astro.params;

let skill = null;
try {
	const res = await fetch(`http://localhost:8000/api/skills/${id}`);
	if (res.ok) {
		skill = await res.json();
	}
} catch (e) {
	console.error(e);
}
---

<Layout title={skill ? `${skill.title} | Bodhic AI` : "Skill Not Found"}>
	{!skill ? (
		<div style="text-align: center; padding: var(--space-4xl);">
			<h2 style="font-size: 24px;">Skill not found</h2>
			<a href="/browse" class="btn btn-primary" style="margin-top: var(--space-md);">Back to Browse</a>
		</div>
	) : (
		<div style="max-width: 800px; margin: 0 auto; padding-top: var(--space-xl);">
			<div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: var(--space-xl);">
				<div>
					<h1 style="margin-bottom: var(--space-xs); font-size: 48px; letter-spacing: -2.4px;">{skill.title}</h1>
					<div style="display: flex; gap: var(--space-xs); margin-top: var(--space-sm);">
						<span class="badge" style="text-transform: uppercase;">{skill.category}</span>
						{skill.scan_summary_json.passed ? (
							<span class="badge success">🛡️ Safe to run</span>
						) : (
							<span class="badge">⚠️ Pending Security Scan</span>
						)}
					</div>
				</div>
			</div>
			
			<div class="glass-card" style="margin-bottom: var(--space-xl);">
				<h2 style="font-size: 20px; font-weight: 600; margin-bottom: var(--space-sm);">Description</h2>
				<p style="color: var(--body); font-size: 16px; white-space: pre-wrap; line-height: 1.6;">{skill.description}</p>
			</div>
			
			<div class="glass-card" style="margin-bottom: var(--space-xl);">
				<h2 style="font-size: 20px; font-weight: 600; margin-bottom: var(--space-sm);">Security Scan Summary (Tier 1)</h2>
				<ul style="color: var(--body); margin-left: 1.5rem; margin-top: var(--space-sm); font-size: 14px;">
					<li style="margin-bottom: 4px;"><strong>Status:</strong> {skill.scan_summary_json.passed ? 'Passed' : 'Flagged'}</li>
					<li style="margin-bottom: 4px;"><strong>Checks Performed:</strong> OWASP LLM01, LLM06, LLM04</li>
					{skill.scan_summary_json.issues && skill.scan_summary_json.issues.length > 0 && (
						<li style="color: var(--error); margin-top: var(--space-sm);">
							<strong>Issues Found:</strong>
							<ul style="margin-left: 1rem; margin-top: 4px;">
								{skill.scan_summary_json.issues.map((i: any) => (
									<li>{i.rule}: {i.description}</li>
								))}
							</ul>
						</li>
					)}
				</ul>
			</div>

			<CheckoutIsland client:load skillId={skill.id} basePrice={skill.base_price_inr || skill.base_price_usd || 0} />
		</div>
	)}
</Layout>
