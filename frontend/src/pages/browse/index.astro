---
import Layout from '../../layouts/Layout.astro';
import BrowseIsland from '../../components/BrowseIsland.tsx';
---

<Layout 
	title="Browse AI Agent Skills & Prompts — Bodhic AI" 
	description="Search our marketplace of verified AI agent skills, prompts, and workflows. Filter by category and price to find the perfect artifact for your next project."
>
	<div style="max-width: 1200px; margin: 0 auto; padding-top: var(--space-2xl);">
		<div style="margin-bottom: var(--space-xl);">
			<span class="eyebrow" style="font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--primary); text-transform: uppercase; letter-spacing: 2px; padding: 6px 16px; background: var(--primary-soft); border-radius: var(--radius-pill); border: 1px solid rgba(108, 60, 225, 0.15); display: inline-block; margin-bottom: var(--space-md);">marketplace</span>
			<h1 style="font-size: 36px; margin-bottom: var(--space-xs);">Browse AI Agent Skills</h1>
			<p style="color: var(--body); font-size: 16px;">Discover secure, verified prompts and agent workflows by domain.</p>
		</div>

		<BrowseIsland client:load />
	</div>
</Layout>
