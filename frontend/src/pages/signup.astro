---
import Layout from '../layouts/Layout.astro';
import AuthForm from '../components/AuthForm.tsx';
---
<Layout title="Sign Up | Agensi Competitor">
	<div style="max-width: 400px; margin: 4rem auto;">
		<div class="glass-card">
			<h1 style="text-align: center; margin-bottom: 2rem;">Create Account</h1>
			
			<AuthForm client:load type="signup" />
			
			<p style="text-align: center; margin-top: 2rem; color: var(--text-secondary);">
				Already have an account? <a href="/login" style="color: var(--accent-color);">Login</a>
			</p>
		</div>
	</div>
</Layout>
