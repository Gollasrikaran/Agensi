---
import Layout from '../layouts/Layout.astro';
import AuthForm from '../components/AuthForm.tsx';
---
<Layout 
	title="Sign Up — Bodhic AI"
	description="Create a Bodhic AI account to buy and sell verified AI agent skills. Join the fastest growing prompt and workflow marketplace."
>
	<div style="max-width: 420px; margin: var(--space-5xl) auto;">
		<div style="text-align: center; margin-bottom: var(--space-xl);">
			<span class="eyebrow" style="font-family: var(--font-mono); font-size: 13px; font-weight: 500; color: var(--primary); text-transform: uppercase; letter-spacing: 2px; padding: 6px 16px; background: var(--primary-soft); border-radius: var(--radius-pill); border: 1px solid rgba(108, 60, 225, 0.15); display: inline-block;">get started</span>
			<h1 style="font-size: 36px; margin-top: var(--space-md); margin-bottom: var(--space-xs);">Create your account.</h1>
			<p style="color: var(--mute);">Join the Bodhic AI marketplace.</p>
		</div>
		<div class="card" style="padding: var(--space-xl);">
			<AuthForm client:load type="signup" />
			<p style="text-align: center; margin-top: var(--space-xl); color: var(--mute); font-size: 14px;">
				Already have an account? <a href="/login" style="color: var(--primary); font-weight: 600;">Login →</a>
			</p>
		</div>
	</div>
</Layout>
