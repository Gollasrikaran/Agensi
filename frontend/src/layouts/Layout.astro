---
import NavbarIsland from '../components/NavbarIsland.tsx';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Bodhic AI - Buy and Sell AI Agent Skills" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<NavbarIsland client:load />
		<main>
			<slot />
		</main>
		<footer>
			<p>&copy; {new Date().getFullYear()} Bodhic AI. All rights reserved.</p>
		</footer>
	</body>
</html>

<style is:global>
	@import "../styles/global.css";
</style>
