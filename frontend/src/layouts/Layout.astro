---
import NavbarIsland from '../components/NavbarIsland.tsx';

export interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
	type?: string;
	jsonLd?: string;
}

const { 
	title, 
	description = "Bodhic AI — Buy and Sell AI Agent Skills. The premier marketplace for prompt artifacts and verified AI agent components.", 
	image = "https://bodhic.app/og-image.png",
	canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://bodhic.app').toString(),
	type = "website",
	jsonLd
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		{jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-ZZ70S6EJ3W"></script>
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());

		  // Only track in production (ignore localhost)
		  if (window.location.hostname !== 'localhost' && window.location.hostname !== '127.0.0.1') {
		      gtag('config', 'G-ZZ70S6EJ3W');
		  }
		</script>
	</head>
	<body>
		<NavbarIsland client:load />
		<main>
			<slot />
		</main>
		<footer style="margin-top: var(--space-5xl); padding: var(--space-xl) 0; border-top: 1px solid var(--hairline); text-align: center;">
			<div class="footer-links" style="display: flex; justify-content: center; gap: var(--space-lg); margin-bottom: var(--space-md); font-size: 14px; flex-wrap: wrap;">
				<a href="/privacy" class="footer-link">Privacy Policy</a>
				<a href="/terms" class="footer-link">Terms & Conditions</a>
				<a href="/refund" class="footer-link">Refund Policy</a>
				<a href="/dmca" class="footer-link">DMCA</a>
				<a href="/security" class="footer-link">Security Scanning</a>
				<a href="/contact" class="footer-link">Contact Us</a>
			</div>
			<p style="color: var(--mute); font-size: 14px;">&copy; {new Date().getFullYear()} Bodhic AI. All rights reserved.</p>
		</footer>
	</body>
</html>

<style is:global>
	@import "../styles/global.css";
	
	.footer-link {
		color: var(--mute);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.footer-link:hover {
		color: var(--primary);
	}
</style>
