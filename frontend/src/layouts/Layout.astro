---
import NavbarIsland from '../components/NavbarIsland.tsx';

export interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
	type?: string;
}

const { 
	title, 
	description = "Bodhic AI — Buy and Sell AI Agent Skills. The premier marketplace for prompt artifacts and verified AI agent components.", 
	image = "https://bodhic.app/og-image.png",
	canonicalURL = new URL(Astro.url.pathname, Astro.site).toString(),
	type = "website"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<!-- Bot-Filtered Analytics -->
		<script is:inline>
			(function() {
				// Only run in production on actual domain
				if (window.location.hostname !== 'bodhic.app') return;

				const ua = navigator.userAgent.toLowerCase();
				const isBot = /cloudflare-worker|headless|bot|spider|crawler|googlebot|bingbot|yandexbot|duckduckbot|slurp/.test(ua);

				if (!isBot) {
					// Inject Google Analytics or tracking here
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', 'G-XXXXXXXXXX'); // Placeholder GA ID
					
					// console.log("Analytics triggered (human user)");
				}
			})();
		</script>
	</head>
	<body>
		<NavbarIsland client:load />
		<main>
			<slot />
		</main>
		<footer style="margin-top: var(--space-5xl); padding: var(--space-xl) 0; border-top: 1px solid var(--hairline); text-align: center;">
			<div style="display: flex; justify-content: center; gap: var(--space-lg); margin-bottom: var(--space-md); font-size: 14px;">
				<a href="/privacy" style="color: var(--mute); text-decoration: none;">Privacy Policy</a>
				<a href="/terms" style="color: var(--mute); text-decoration: none;">Terms & Conditions</a>
				<a href="/refund" style="color: var(--mute); text-decoration: none;">Refund Policy</a>
				<a href="/contact" style="color: var(--mute); text-decoration: none;">Contact Us</a>
			</div>
			<p style="color: var(--mute); font-size: 14px;">&copy; {new Date().getFullYear()} Bodhic AI. All rights reserved.</p>
		</footer>
	</body>
</html>

<style is:global>
	@import "../styles/global.css";
</style>
