---
import NavbarIsland from '../components/NavbarIsland.tsx';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Bodhic AI — Buy and Sell AI Agent Skills" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<NavbarIsland client:load />
		<main>
			<slot />
		</main>
		<footer style="margin-top: var(--space-5xl); padding: var(--space-xl) 0; border-top: 1px solid var(--hairline); text-align: center;">
			<p style="color: var(--mute); font-size: 14px;">&copy; {new Date().getFullYear()} Bodhic AI. All rights reserved.</p>
		</footer>
	</body>
</html>

<style is:global>
	@import "../styles/global.css";
</style>
